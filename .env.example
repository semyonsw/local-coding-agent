# Required: your Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY="your_api_key_here"

# Agent limits (keep these reasonable to avoid runaway costs)
GEMINI_MAX_TURNS=25
GEMINI_MAX_TOOL_CALLS=50
GEMINI_COMMAND_TIMEOUT_MS=15000

# Optional settings
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_WEB_PORT=7789
# GEMINI_ALLOW_OUTSIDE_ROOT=false
# GEMINI_LOG_LEVEL=info
# GEMINI_LOG_DIR=logs
# GEMINI_LOG_MAX_BYTES=5000000
